# Copy this file to .env.local and fill in your values.
# Never commit .env.local (it is in .gitignore).

# ---------------------------------------------------------------------------
# Google Places API (address autocomplete on contact form)
# ---------------------------------------------------------------------------
# 1. Go to https://console.cloud.google.com/
# 2. Create or select a project → APIs & Services → Enable "Places API" (New)
#    or "Places API" and "Geocoding API" if using older API.
# 3. Create credentials → API key. Restrict by HTTP referrer in production.
# GOOGLE_PLACES_API_KEY=your_google_places_api_key

# ---------------------------------------------------------------------------
# Resend (contact form email delivery)
# ---------------------------------------------------------------------------
# Create a key at https://resend.com/api-keys (keys start with re_).
# Set in .env.local with no quotes, then restart the dev server:
#   RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Where to receive contact form submissions (your business email)
# CONTACT_FORM_TO_EMAIL=info@roofix.com.au

# Optional: sender name and address. If unset, uses Resend's test sender
# (onboarding@resend.dev) — you can only send to your Resend account email then.
# Add and verify your domain at https://resend.com/domains then set e.g.:
# CONTACT_FORM_FROM_EMAIL=Roofix Website <noreply@yourdomain.com>

# ---------------------------------------------------------------------------
# Firebase (admin panel + public read)
# ---------------------------------------------------------------------------
# Both required for the public site (home, /services, /projects) to show content
# from the control centre. Without them, the site uses static fallback data.
# Project ID from Firebase Console → Project settings
# FIREBASE_PROJECT_ID=your-project-id

# Service account key for server-side Firestore read. Use one of:
# (A) In dev, path to the JSON file (avoids paste corruption of the private key):
#     FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./path/to/your-service-account-key.json
# (B) Full JSON as one line (or run: node -e "console.log(JSON.stringify(require('./path/to/key.json')))"):
#     FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project",...}

# Optional: Realtime Database URL (only if you use RTDB).
# FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# Client config for /control-centre (auth, Firestore write, Storage upload).
# Firebase Console → Project settings → General → Your apps → Web app.
# NEXT_PUBLIC_FIREBASE_API_KEY=...
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=...
# NEXT_PUBLIC_FIREBASE_APP_ID=...

# ---------------------------------------------------------------------------
# Google Analytics 4 (public site only; control-centre has no GA)
# ---------------------------------------------------------------------------
# Measurement ID from GA4 property → Admin → Data Streams → Web → Measurement ID (G-XXXX)
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# GA4 Property ID (numeric) for control-centre Analytics page (custom dashboard). Same property as above.
# GA4 Admin → Property settings → Property ID. Enable "Google Analytics Data API" in Google Cloud
# and add your Firebase service account email to the GA4 property as a Viewer.
# GA4_PROPERTY_ID=123456789

# Optional: "Active right now" scope uses GA4 data stream IDs (hostnames map to streams in GA4).
# Create separate web streams for public site (roofix.com.au + www) and admin (admin.roofix.com.au)
# if you want Public / Admin / All toggles. GA4 Admin → Data streams → Stream ID in URL or details.
# GA4_MAIN_STREAM_ID=1234567890
# GA4_ADMIN_STREAM_ID=9876543210

# ---------------------------------------------------------------------------
# Google Business Profile (import reviews into Control Centre Testimonials)
# ---------------------------------------------------------------------------
# Optional. To import reviews:
# 1. Request API access (required): The My Business API is not public. Submit an
#    application at https://support.google.com/business/contact/api_default
#    (choose "Application for Basic API Access"). Your Business Profile must be
#    verified and active for 60+ days. After approval, quota will show 300 QPM
#    (0 QPM means not yet approved).
# 2. In Google Cloud Console → APIs & Services → Enable:
#    - "My Business Business Information API" (mybusinessbusinessinformation)
#    - "Google My Business API" (mybusiness)
# 3. Create OAuth 2.0 credentials (APIs & Services → Credentials → Create
#    credentials → OAuth client ID; type Desktop or Web). For Web, add redirect
#    URI https://developers.google.com/oauthplayground if using Playground.
# 4. One-time OAuth: Use OAuth 2.0 Playground (https://developers.google.com/
#    oauthplayground) or your app. Scope: https://www.googleapis.com/auth/
#    business.manage. Authorize, then exchange the code for tokens and save
#    the refresh_token here.
# 5. Get account and location IDs: e.g. call GET
#    https://mybusinessaccountmanagement.googleapis.com/v1/accounts (with
#    Bearer token) to list accounts; then use the My Business API to get
#    locations for that account. Or use a tool that lists your GBP account/location.
# 6. Restart the dev server after adding or changing these env vars.
# GOOGLE_GBP_ACCOUNT_ID=12345678901234567890
# GOOGLE_GBP_LOCATION_ID=12345678901234567890
# GOOGLE_GBP_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_GBP_CLIENT_SECRET=xxx
# GOOGLE_GBP_REFRESH_TOKEN=xxx

# ---------------------------------------------------------------------------
# Web Push (control centre: new lead & lead accepted notifications)
# ---------------------------------------------------------------------------
# Generate keys: npx web-push generate-vapid-keys
# Add both to .env.local. If unset, "Notify me" is shown but saving subscription returns 503.
# VAPID_PUBLIC_KEY=BN...
# VAPID_PRIVATE_KEY=...

# ---------------------------------------------------------------------------
# Local leads scanner (npm run scanner-worker)
# ---------------------------------------------------------------------------
# After Connect in the control centre, each source gets session files under the repo:
#   .auth/sources/<sourceId>/storage-state.leads.json  — leads worker, actions, analyze page
#   .auth/sources/<sourceId>/storage-state.jobs.json  — Hipages job-page flows (e.g. Fetch customer); bootstraps from leads if missing
# Reconnect once to create both files; see lib/leads/connection/session-persistence.ts.

# Optional: PM2 “paused” when all sources are paused in the UI (second process; PM2 5+ shows paused)
# SCANNER_PM2_APP_NAME=roofix-scanner
# npm run scanner-pm2-watch
# Or: pm2 start ecosystem.config.cjs
# SCANNER_PM2_WATCH_POLL_MS=5000

# ---------------------------------------------------------------------------
# Production (Firebase App Hosting)
# ---------------------------------------------------------------------------
# Same APIs and storage as local. Set env and secrets in apphosting.yaml;
# create secrets in Google Cloud Secret Manager. Deploy rules: npm run deploy:rules
# See DEPLOYMENT.md for full steps.
